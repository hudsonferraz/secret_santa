// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organizer {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String
  password_hash String
  created_at    DateTime @default(now())
  events        Event[]
}

model Event {
  id Int @id @default(autoincrement())
  id_organizer Int
  status Boolean @default(false)
  title String
  description String
  grouped Boolean @default(false)
  organizer Organizer @relation(fields: [id_organizer], references: [id], onDelete: Cascade)
  EventGroup EventGroup[]
  EventPeople EventPeople[]
}

model EventGroup {
  id Int @id @default(autoincrement())
  id_event Int
  name String
  event Event @relation(fields: [id_event], references: [id], onDelete: Cascade)
  EventPeople EventPeople[]
}

model EventPeople {
  id Int @id @default(autoincrement())
  id_event Int
  id_group Int
  name String
  phone_number String?
  reveal_token String @unique @default(uuid())
  matched String @default("")

  event Event @relation(fields: [id_event], references: [id], onDelete: Cascade)
  group EventGroup @relation(fields: [id_group], references: [id], onDelete: Cascade)
}